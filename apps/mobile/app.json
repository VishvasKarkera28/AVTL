{
  "expo": {
    "name": "FlashAVTL",
    "slug": "flashfleet-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/flashavtl-logo.png",
    "scheme": "flashavtl",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/flashavtl-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#06101E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.avtl.flashfleet"
    },
    "android": {
      "package": "com.avtl.flashfleet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/flashavtl-logo.png",
        "backgroundColor": "#17212B"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
